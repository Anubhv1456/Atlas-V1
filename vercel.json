{
  "buildCommand": "pnpm run build && mkdir -p dist && cp -r artifacts/study-tracker/dist/* dist/",
  "installCommand": "pnpm install",
  "nodeVersion": "20.x",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "^(?!/api/).*",
      "dest": "/index.html"
    }
  ]
}
